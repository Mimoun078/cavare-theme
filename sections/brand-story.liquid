<section class="brand-story">
  <div class="brand-story__image-wrap">
    {%- if section.settings.image != blank -%}
      <img
        class="brand-story__image"
        src="{{ section.settings.image | image_url: width: 1200 }}"
        alt="{{ section.settings.image.alt | default: 'Cavarè' }}"
        loading="lazy"
      >
    {%- else -%}
      <div class="brand-story__image" style="background: #2A1B0F;"></div>
    {%- endif -%}
  </div>

  <div class="brand-story__content">
    {%- if section.settings.label != blank -%}
      <span class="brand-story__label">{{ section.settings.label }}</span>
    {%- endif -%}
    <h2 class="brand-story__title">{{ section.settings.title }}</h2>
    <p class="brand-story__text">{{ section.settings.text }}</p>
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_url }}" class="btn btn--light">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Merkverhaal",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Foto"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Klein label",
      "default": "Ons Verhaal"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titel",
      "default": "Gemaakt met Intentie"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Tekst",
      "default": "Cavarè is geboren vanuit een passie voor tijdloze kwaliteit. Elk stuk is met zorg geselecteerd — ontworpen om generaties mee te gaan. Geen trends. Geen compromissen. Alleen kleding die je beter maakt."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Knoptekst",
      "default": "Lees ons verhaal"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Knop link"
    }
  ],
  "presets": [
    {
      "name": "Merkverhaal"
    }
  ]
}
{% endschema %}
