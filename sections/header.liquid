<style>
  .cv-header { position: sticky; top: 0; z-index: 100; background: #FEFEFE; border-bottom: 1px solid #E8E2DB; }
  .cv-header__bar { max-width: 1280px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; height: 68px; }
  .cv-header__left { display: flex; align-items: center; }
  .cv-header__center { text-align: center; }
  .cv-header__right { display: flex; align-items: center; justify-content: flex-end; gap: 1.5rem; }
  .cv-header__logo { font-family: 'Cinzel', 'Georgia', serif; font-size: 1.15rem; letter-spacing: 0.35em; color: #231F20; text-decoration: none; font-weight: 400; }
  .cv-header__logo img { height: 32px; width: auto; }
  .cv-header__hamburger { background: none; border: none; cursor: pointer; padding: 4px; display: flex; flex-direction: column; gap: 5px; }
  .cv-header__hamburger span { display: block; width: 22px; height: 1.5px; background: #231F20; transition: opacity 0.2s; }
  .cv-header__hamburger:hover span { opacity: 0.5; }
  .cv-header__icon { color: #231F20; text-decoration: none; display: flex; align-items: center; position: relative; transition: opacity 0.2s; }
  .cv-header__icon:hover { opacity: 0.5; }
  .cv-header__cart-count { position: absolute; top: -6px; right: -8px; background: #2A1B0F; color: #FEFEFE; font-size: 0.5rem; width: 15px; height: 15px; border-radius: 50%; display: none; align-items: center; justify-content: center; font-family: 'Inter', sans-serif; }

  /* Full-screen nav overlay */
  .cv-nav { display: none; position: fixed; inset: 0; background: #FEFEFE; z-index: 200; flex-direction: column; padding: 0 3rem; justify-content: center; }
  .cv-nav.open { display: flex; }
  .cv-nav__close { position: absolute; top: 1.5rem; right: 1.5rem; background: none; border: none; cursor: pointer; font-size: 1.5rem; color: #231F20; padding: 8px; line-height: 1; }
  .cv-nav__links { display: flex; flex-direction: column; gap: 0; }
  .cv-nav__links a { font-family: 'Cinzel', 'Georgia', serif; font-size: clamp(1.6rem, 4vw, 3rem); font-weight: 400; letter-spacing: 0.08em; color: #231F20; text-decoration: none; padding: 0.75rem 0; border-bottom: 1px solid #E8E2DB; transition: color 0.2s; display: block; }
  .cv-nav__links a:first-child { border-top: 1px solid #E8E2DB; }
  .cv-nav__links a:hover { color: #7A6E65; }
  .cv-nav__circle { font-family: 'Cinzel', 'Georgia', serif; font-size: clamp(1.6rem, 4vw, 3rem); font-weight: 400; letter-spacing: 0.08em; color: #7A6E65; text-decoration: none; padding: 0.75rem 0; border-bottom: 1px solid #E8E2DB; transition: color 0.2s; display: block; font-style: italic; }
  .cv-nav__circle:hover { color: #2A1B0F; }
  .cv-nav__footer { margin-top: 2.5rem; display: flex; align-items: center; justify-content: space-between; }
  .cv-nav__footer p { font-family: 'Inter', sans-serif; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: #7A6E65; margin: 0; }
  .cv-nav__lang { font-family: 'Inter', sans-serif; font-size: 0.68rem; letter-spacing: 0.15em; color: #7A6E65; display: flex; gap: 0.5rem; align-items: center; }
  .cv-nav__lang a { color: #7A6E65; text-decoration: none; transition: color 0.2s; }
  .cv-nav__lang a:hover { color: #231F20; }
  .cv-nav__lang span { opacity: 0.4; }
</style>

<header class="cv-header">
  <div class="cv-header__bar">

    <div class="cv-header__left">
      <button class="cv-header__hamburger" id="cv-nav-open" aria-label="Menu openen">
        <span></span><span></span><span></span>
      </button>
    </div>

    <div class="cv-header__center">
      <a href="/" class="cv-header__logo">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 300 }}" alt="{{ shop.name }}" width="{{ section.settings.logo_width }}" height="auto">
        {%- else -%}
          CAVARÈ
        {%- endif -%}
      </a>
    </div>

    <div class="cv-header__right">
      <a href="/cart" class="cv-header__icon" aria-label="Winkelwagen">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="cv-header__cart-count" id="cv-cart-count">0</span>
      </a>
    </div>

  </div>
</header>

<nav class="cv-nav" id="cv-nav">
  <button class="cv-nav__close" id="cv-nav-close" aria-label="Menu sluiten">&#10005;</button>
  <div class="cv-nav__links">
    <a href="/collections/nieuw-binnen" onclick="cvNavClose()">Nieuw</a>
    <a href="/collections/all" onclick="cvNavClose()">Shop</a>
    <a href="/pages/shop-the-look" onclick="cvNavClose()">Shop the Look</a>
    <a href="/pages/over-ons" onclick="cvNavClose()">Over Cavarè</a>
    <a href="/pages/contact" onclick="cvNavClose()">Contact</a>
    <a href="/pages/cavare-circle" class="cv-nav__circle" onclick="cvNavClose()">The Cavarè Circle</a>
  </div>
  <div class="cv-nav__footer">
    <p>Cavarè &mdash; Made to last.</p>
    <div class="cv-nav__lang">
      <a href="/">NL</a>
      <span>/</span>
      <a href="/en">EN</a>
    </div>
  </div>
</nav>

<script>
  function cvNavClose() {
    document.getElementById('cv-nav').classList.remove('open');
    document.body.style.overflow = '';
  }
  document.getElementById('cv-nav-open').addEventListener('click', function() {
    document.getElementById('cv-nav').classList.add('open');
    document.body.style.overflow = 'hidden';
  });
  document.getElementById('cv-nav-close').addEventListener('click', cvNavClose);
  fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
    var badge = document.getElementById('cv-cart-count');
    if (cart.item_count > 0) {
      badge.textContent = cart.item_count;
      badge.style.display = 'flex';
    }
  });
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "range", "id": "logo_width", "min": 80, "max": 300, "step": 10, "default": 140, "unit": "px", "label": "Logo breedte" }
  ]
}
{% endschema %}
