<style>
  .cavare-hero {
    position: relative;
    height: 92vh;
    min-height: 550px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }
  .cavare-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }
  .cavare-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(35,31,32,0.75) 0%, rgba(35,31,32,0.2) 50%, transparent 100%);
  }
  .cavare-hero__content {
    position: relative;
    z-index: 10;
    padding: 4rem 2rem 5rem;
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
    color: #FEFEFE;
  }
  .cavare-hero__label {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
    opacity: 0.85;
    color: #FEFEFE;
  }
  .cavare-hero__title {
    font-family: 'Cinzel', 'Georgia', serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 400;
    letter-spacing: 0.05em;
    line-height: 1.15;
    margin-bottom: 1.5rem;
    color: #FEFEFE;
    max-width: 700px;
  }
  .cavare-hero__subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    opacity: 0.85;
    margin-bottom: 2.5rem;
    color: #FEFEFE;
    max-width: 400px;
  }
  .cavare-hero__btn {
    display: inline-block;
    padding: 0.9rem 2.5rem;
    background: transparent;
    border: 1.5px solid #FEFEFE;
    color: #FEFEFE;
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .cavare-hero__btn:hover {
    background: #FEFEFE;
    color: #2A1B0F;
  }
  @media (max-width: 768px) {
    .cavare-hero { height: 80vh; }
    .cavare-hero__content { padding: 3rem 1.25rem 4rem; }
  }
</style>

<section class="cavare-hero">
  {%- if section.settings.image != blank -%}
    <img class="cavare-hero__img" src="{{ section.settings.image | image_url: width: 2000 }}" alt="{{ section.settings.image.alt | default: 'Cavarè Clothing' }}" loading="eager" fetchpriority="high">
  {%- else -%}
    <img class="cavare-hero__img" src="{{ 'cavare-model.jpeg' | asset_url }}" alt="Cavarè Clothing" loading="eager" fetchpriority="high">
  {%- endif -%}

  <div class="cavare-hero__overlay"></div>

  <div class="cavare-hero__content">
    {%- if section.settings.label != blank -%}
      <span class="cavare-hero__label">{{ section.settings.label }}</span>
    {%- endif -%}
    <h1 class="cavare-hero__title">{{ section.settings.title | newline_to_br }}</h1>
    {%- if section.settings.subtitle != blank -%}
      <p class="cavare-hero__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="cavare-hero__btn">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Achtergrond foto"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Klein label",
      "default": "Nieuwe Collectie"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Hoofdtitel",
      "default": "Modern Elegance.\nTimeless Simplicity."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Ondertitel",
      "default": "Crafted in Italy. Made to last."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Knoptekst",
      "default": "Bekijk de collectie"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Knop link"
    }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
