<style>
  .cv-hero { position: relative; height: 92vh; min-height: 560px; overflow: hidden; display: flex; align-items: center; justify-content: center; }
  .cv-hero__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 20%; }
  .cv-hero__overlay { position: absolute; inset: 0; background: rgba(35,31,32,0.35); }
  .cv-hero__content { position: relative; z-index: 10; text-align: center; padding: 2rem; color: #FEFEFE; max-width: 720px; }
  .cv-hero__label { display: block; font-family: 'Inter', sans-serif; font-size: 0.68rem; letter-spacing: 0.28em; text-transform: uppercase; color: rgba(254,254,254,0.85); margin-bottom: 1.2rem; }
  .cv-hero__title { font-family: 'Cinzel', 'Georgia', serif; font-size: clamp(2rem, 5.5vw, 4.5rem); font-weight: 400; letter-spacing: 0.06em; line-height: 1.2; color: #FEFEFE; margin: 0 0 1.8rem; }
  .cv-hero__subtitle { font-family: 'Inter', sans-serif; font-size: 0.9rem; letter-spacing: 0.08em; color: rgba(254,254,254,0.8); margin-bottom: 2.5rem; }
  .cv-hero__btn { display: inline-block; padding: 0.85rem 2.8rem; border: 1px solid rgba(254,254,254,0.8); color: #FEFEFE; font-family: 'Inter', sans-serif; font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; text-decoration: none; transition: all 0.3s ease; }
  .cv-hero__btn:hover { background: #FEFEFE; color: #231F20; border-color: #FEFEFE; }
  @media (max-width: 768px) { .cv-hero { height: 80vh; } }
</style>

<section class="cv-hero">
  {%- if section.settings.image != blank -%}
    <img class="cv-hero__img" src="{{ section.settings.image | image_url: width: 2000 }}" alt="{{ section.settings.image.alt | default: 'Cavarè Clothing' }}" loading="eager" fetchpriority="high">
  {%- else -%}
    <img class="cv-hero__img" src="{{ 'cavare-model.jpeg' | asset_url }}" alt="Cavarè Clothing" loading="eager" fetchpriority="high">
  {%- endif -%}

  <div class="cv-hero__overlay"></div>

  <div class="cv-hero__content">
    {%- if section.settings.label != blank -%}
      <span class="cv-hero__label">{{ section.settings.label }}</span>
    {%- endif -%}
    <h1 class="cv-hero__title">{{ section.settings.title | newline_to_br }}</h1>
    {%- if section.settings.subtitle != blank -%}
      <p class="cv-hero__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="cv-hero__btn">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Achtergrond foto" },
    { "type": "text", "id": "label", "label": "Klein label", "default": "Nieuwe Collectie" },
    { "type": "text", "id": "title", "label": "Hoofdtitel", "default": "Modern Elegance.\nTimeless Simplicity." },
    { "type": "text", "id": "subtitle", "label": "Ondertitel", "default": "Crafted in Italy. Made to last." },
    { "type": "text", "id": "button_label", "label": "Knoptekst", "default": "Shop Nu" },
    { "type": "url", "id": "button_url", "label": "Knop link" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
