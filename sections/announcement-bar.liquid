<style>
  .cv-bar { background: #231F20; color: #FEFEFE; text-align: center; padding: 0.65rem 1rem; }
  .cv-bar p { font-family: 'Inter', sans-serif; font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; margin: 0; color: #FEFEFE; }
  .cv-bar a { color: #FEFEFE; text-decoration: none; }
  .cv-bar a:hover { opacity: 0.7; }
</style>

<div class="cv-bar">
  <p>
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
    {%- else -%}
      {{ section.settings.text }}
    {%- endif -%}
  </p>
</div>

{% schema %}
{
  "name": "Aankondigingsbalk",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Tekst",
      "default": "Gratis verzending bij bestellingen boven €75"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optioneel)"
    }
  ],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
