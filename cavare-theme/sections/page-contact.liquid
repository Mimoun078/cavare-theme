<div class="contact-page">
  <h1 class="contact-page__title">{{ section.settings.title | default: 'Contact' }}</h1>
  <p class="contact-page__subtitle">{{ section.settings.subtitle | default: 'Heb je een vraag? We helpen je graag.' }}</p>

  {%- form 'contact' -%}
    {%- if form.posted_successfully? -%}
      <div style="background:#F0EBE3; padding:1.5rem; text-align:center; margin-bottom:2rem;">
        <p style="font-family:'Cinzel',serif; letter-spacing:0.1em;">Bericht verzonden. We nemen zo snel mogelijk contact op.</p>
      </div>
    {%- endif -%}

    <div class="contact-form">
      <div class="form-group">
        <label for="contact-name">Naam</label>
        <input type="text" id="contact-name" name="contact[name]" value="{{ form.name }}" placeholder="Jouw naam" required>
      </div>

      <div class="form-group">
        <label for="contact-email">E-mailadres</label>
        <input type="email" id="contact-email" name="contact[email]" value="{{ form.email }}" placeholder="jouw@email.nl" required>
      </div>

      <div class="form-group">
        <label for="contact-message">Bericht</label>
        <textarea id="contact-message" name="contact[body]" placeholder="Jouw bericht..." required>{{ form.body }}</textarea>
      </div>

      <button type="submit" class="btn btn--primary btn--full">Verstuur bericht</button>
    </div>
  {%- endform -%}

  {%- if section.settings.email != blank or section.settings.instagram != blank -%}
    <div style="margin-top:3rem; padding-top:2rem; border-top:1px solid #E0D8CF;">
      {%- if section.settings.email != blank -%}
        <p style="font-size:0.85rem; color:#7A6E65; margin-bottom:0.5rem;">
          E-mail: <a href="mailto:{{ section.settings.email }}" style="color:#2A1B0F;">{{ section.settings.email }}</a>
        </p>
      {%- endif -%}
      {%- if section.settings.instagram != blank -%}
        <p style="font-size:0.85rem; color:#7A6E65;">
          Instagram: <a href="{{ section.settings.instagram }}" target="_blank" style="color:#2A1B0F;">@cavareclothing</a>
        </p>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Contact pagina",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Paginatitel",
      "default": "Contact"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Ondertitel",
      "default": "Heb je een vraag? We helpen je graag."
    },
    {
      "type": "text",
      "id": "email",
      "label": "E-mailadres"
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    }
  ]
}
{% endschema %}
